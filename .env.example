PORT=3000
NODE_ENV=development

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/rarecheck

# JWT
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Pokemon TCG API (optional — free tier is rate-limited)
POKEMON_TCG_API_KEY=

# Price cache TTL in hours
PRICE_CACHE_TTL_HOURS=6

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_GENERAL=60
RATE_LIMIT_MAX_IDENTIFY=10
